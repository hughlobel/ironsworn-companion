{
  "name": "ironsworn-mcp",
  "version": "1.0.0",
  "description": "Ironsworn MCP server for Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy-data",
    "copy-data": "node -e \"const fs=require('fs');fs.cpSync('src/data','dist/data',{recursive:true})\"",
    "extract-data": "tsx src/extract-data.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
